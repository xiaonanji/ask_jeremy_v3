OPENAI_API_KEY=
DEFAULT_OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_AVAILABLE_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024
CORS_ORIGINS=http://localhost:5173
ANTHROPIC_AVAILABLE_MODELS=claude-sonnet-4-20250514,claude-opus-4-20250514

TRUST_PROJECT_SKILLS=true
DEFAULT_DATABASE_BACKEND=sqlite
SQLITE_DATABASE_PATH=
SQL_QUERY_MAX_ROWS=1000
SQL_QUERY_TIMEOUT_SECONDS=30
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_AUTHENTICATOR=externalbrowser

PERSON_WIKI_ROOT=


